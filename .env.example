# Hugging Face token (required for diarization via pyannote)
HF_TOKEN=

# Vast.ai serverless settings (used by test.py)
VAST_API_KEY=
VAST_ENDPOINT_NAME=
VAST_ROUTE_URL=https://run.vast.ai/route/

# Model server
MODEL_NAME=large-v3
WHISPER_COMPUTE_TYPE=float16
WHISPER_BATCH_SIZE=8
DEFAULT_TASK=transcribe
DEFAULT_LANGUAGE=
MAX_AUDIO_SECONDS=1800
MAX_AUDIO_SIZE_MB=100
MAX_BASE64_BYTES=104857600
OUTPUT_DIR=/workspace/outputs
TMP_ROOT=/workspace/workspace_tmp
DEMUCS_MODEL=htdemucs
# Optional explicit path/name for demucs CLI, e.g. /opt/model-venv/bin/demucs
DEMUCS_EXECUTABLE=
ENABLE_DEMUCS_BY_DEFAULT=true
ENABLE_DIARIZATION_BY_DEFAULT=false
STARTUP_SELF_TEST=true
STARTUP_SELF_TEST_STRICT=false
SELF_TEST_AUDIO_URL=https://raw.githubusercontent.com/openai/whisper/main/tests/jfk.flac

# Worker
MODEL_SERVER_URL=http://127.0.0.1
MODEL_SERVER_PORT=8000
MODEL_LOG_FILE=/workspace/model.log
DEFAULT_WORKLOAD_SECONDS=60
MAX_WORKLOAD_SECONDS=3600
